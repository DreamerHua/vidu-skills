#!/usr/bin/env python3
"""vidu-cli — Vidu API wrapper for structured JSON output."""

import argparse
import os
import sys

# Ensure scripts/ is on path when invoked directly
sys.path.insert(0, os.path.dirname(__file__))


def main():
    parser = argparse.ArgumentParser(prog="vidu-cli", description="Vidu API CLI")
    sub = parser.add_subparsers(dest="group", required=True)

    # vidu upload <image_path>
    p_upload = sub.add_parser("upload", help="Upload image → ssupload_uri")
    p_upload.add_argument("image_path")

    # vidu task <subcommand>
    p_task = sub.add_parser("task", help="Task operations")
    task_sub = p_task.add_subparsers(dest="action", required=True)

    p_submit = task_sub.add_parser("submit", help="Submit task")
    p_submit.add_argument("--type", required=True, dest="task_type",
                          choices=["text2image", "text2video", "img2video",
                                   "headtailimg2video", "reference2image", "character2video"],
                          help="Task type")
    p_submit.add_argument("--prompt", required=True, help="Text prompt")
    p_submit.add_argument("--image", action="append", default=[], help="Image ssupload_uri (repeatable)")
    p_submit.add_argument("--material", action="append", default=[], help="Material ref name:id:version (repeatable)")
    p_submit.add_argument("--duration", type=int, required=True, help="Duration in seconds (0 for image)")
    p_submit.add_argument("--model-version", required=True, help="Model version: 3.0|3.1|3.2|3.2_fast_m|3.2_pro_m")
    p_submit.add_argument("--aspect-ratio", default=None, help="Aspect ratio: 16:9|9:16|1:1|4:3|3:4")
    p_submit.add_argument("--transition", default=None, help="Transition: pro|speed|creative|stable")
    p_submit.add_argument("--resolution", required=True, help="Resolution: 1080p|2k|4k")
    p_submit.add_argument("--sample-count", type=int, default=1, help="Sample count (default 1)")
    p_submit.add_argument("--codec", default="h265", help="Codec (default h265)")
    p_submit.add_argument("--movement-amplitude", default="auto", help="Movement amplitude (default auto)")
    p_submit.add_argument("--schedule-mode", default="normal", help="Schedule mode (default normal)")

    p_get = task_sub.add_parser("get", help="Get task result")
    p_get.add_argument("task_id")

    p_sse = task_sub.add_parser("sse", help="Stream SSE task state")
    p_sse.add_argument("task_id")

    # vidu element <subcommand>
    p_el = sub.add_parser("element", help="Element (主体) operations")
    el_sub = p_el.add_subparsers(dest="action", required=True)

    p_pre = el_sub.add_parser("preprocess", help="Pre-process element")
    p_pre.add_argument("--name", required=True, help="Element name")
    p_pre.add_argument("--type", default="user", dest="elem_type", help="Element type (default user)")
    p_pre.add_argument("--image", action="append", required=True, help="Image ssupload_uri (repeatable, 1-3)")

    p_create = el_sub.add_parser("create", help="Create element")
    p_create.add_argument("--id", required=True, dest="elem_id", help="ID from preprocess response")
    p_create.add_argument("--name", required=True, help="Element name")
    p_create.add_argument("--modality", default="image", help="Modality (default image)")
    p_create.add_argument("--type", default="user", dest="elem_type", help="Element type (default user)")
    p_create.add_argument("--image", action="append", required=True, help="Image ssupload_uri (repeatable)")
    p_create.add_argument("--version", default="0", help="Version (default 0)")
    p_create.add_argument("--description", required=True, help="Description text")

    p_list = el_sub.add_parser("list", help="List personal elements")
    p_list.add_argument("--keyword", default=None)
    p_list.add_argument("--page", type=int, default=0)
    p_list.add_argument("--pagesz", type=int, default=20)

    p_search = el_sub.add_parser("search", help="Search community elements")
    p_search.add_argument("--keyword", required=True)
    p_search.add_argument("--pagesz", type=int, default=20)
    p_search.add_argument("--sort-by", default="recommend")
    p_search.add_argument("--page-token", default="")

    args = parser.parse_args()

    if args.group == "upload":
        from commands.upload import run
        run(args.image_path)

    elif args.group == "task":
        from commands import tasks
        if args.action == "submit":
            tasks.submit(
                task_type=args.task_type,
                prompt=args.prompt,
                images=args.image,
                materials=args.material,
                duration=args.duration,
                model_version=args.model_version,
                aspect_ratio=args.aspect_ratio,
                transition=args.transition,
                resolution=args.resolution,
                sample_count=args.sample_count,
                codec=args.codec,
                movement_amplitude=args.movement_amplitude,
                schedule_mode=args.schedule_mode,
            )
        elif args.action == "get":
            tasks.get(args.task_id)
        elif args.action == "sse":
            tasks.sse(args.task_id)

    elif args.group == "element":
        from commands import elements
        if args.action == "preprocess":
            elements.preprocess(
                name=args.name,
                elem_type=args.elem_type,
                images=args.image,
            )
        elif args.action == "create":
            elements.create(
                elem_id=args.elem_id,
                name=args.name,
                modality=args.modality,
                elem_type=args.elem_type,
                images=args.image,
                version=args.version,
                description=args.description,
            )
        elif args.action == "list":
            elements.list_elements(keyword=args.keyword, page=args.page, pagesz=args.pagesz)
        elif args.action == "search":
            elements.search(keyword=args.keyword, pagesz=args.pagesz, sort_by=args.sort_by, page_token=args.page_token)


if __name__ == "__main__":
    main()
